# ============================================================
#  .env サンプル。本番は `cp .env.example .env` して値を埋める。
#  本番デプロイ手順は docs/デプロイ_AWS.md を参照。
# ============================================================

# ---- アプリ ----
APP_ENV=production
APP_URL=https://your-domain.example   # https:// 必須（本番ガードが検証）。↓DOMAINと一致させる
APP_TIMEZONE=Asia/Tokyo               # 表示・保存に使うタイムゾーン（PHPとMySQLセッションで共有）

# ---- 本番ドメイン / TLS（docker-compose.prod.yml / Caddy 用）----
DOMAIN=your-domain.example            # 取得した独自ドメイン（www無し）。CaddyがこのFQDNで証明書を自動取得
ACME_EMAIL=you@example.com            # Let's Encrypt 登録メール（証明書期限の通知先）

# ---- ポート（開発用 docker-compose.yml 専用。本番prodでは未使用）----
NGINX_PORT=80
NGINX_TLS_PORT=443
DB_PORT=13306
MAILPIT_UI_PORT=8025                   # 本番では mailpit を起動しない

# ---- データベース ----
DB_NAME=bbs
DB_USER=bbs
DB_PASSWORD=            # 本番は強力な秘密に。空/bbs/root/password/changeme は起動拒否される
DB_ROOT_PASSWORD=      # これも強力な秘密に

# ---- メール（本番=SMTPプロバイダ。例: Amazon SES）----
MAIL_DRIVER=smtp                       # 本番は smtp 必須（log だと実送信されず起動拒否）
MAIL_HOST=email-smtp.ap-northeast-1.amazonaws.com   # 例: SES東京リージョン
MAIL_PORT=587
MAIL_USERNAME=                         # SES の SMTP ユーザー名（IAM認証情報とは別物）
MAIL_PASSWORD=                         # SES の SMTP パスワード
MAIL_ENCRYPTION=tls                    # none | tls(STARTTLS) | ssl
MAIL_FROM=no-reply@your-domain.example # SESで検証済みの送信元アドレス/ドメイン
MAIL_FROM_NAME=BBS BATTLE CHAOS

# ---- 法務ページの運営者表記（M5。/terms ・ /privacy に表示）----
LEGAL_OPERATOR=相馬主水  # 運営者名（個人名/屋号/法人名など実体に合わせる）
LEGAL_CONTACT=  # 問い合わせ先メール（実際に届くアドレスを設定。開示・問い合わせ窓口）

# ---- Googleアカウントログイン（OAuth/OIDC。任意。空ならボタン非表示・導線無効）----
#  Google Cloud Console > APIとサービス > 認証情報 で「OAuthクライアントID（ウェブ）」を作成し、
#  「承認済みのリダイレクトURI」に GOOGLE_REDIRECT_URL と同じ値を登録すること。
GOOGLE_CLIENT_ID=        # 例: xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=    # クライアントシークレット
GOOGLE_REDIRECT_URL=     # 未設定なら APP_URL + /auth/google/callback（例: https://your-domain.example/auth/google/callback）

# ---- ゲームバランス調整（M3。任意。未設定なら App\Config\Game の既定値）----
#  クローズドβで計測した結果に応じて、再ビルド無しで以下を上書きできる。
#  詳細は docs/ゲームバランス調整.md を参照。コメントアウト中は既定値が使われる。
# GAME_INITIAL_MONEY=500          # 初期所持金
# GAME_MIN_INVEST=1               # 最小投資額
# GAME_SPLIT_SHARES=0.70          # 投資額のうち株取得に回す割合（残りはHP回復）
# GAME_SHARE_PRICE_BASE=10        # 株価ボンディングカーブの基準値
# GAME_SHARE_PRICE_SLOPE=0.01     # 株価の傾き（累計投資×slope）
# GAME_POST_LEVEL_TIERS=100,1000,10000      # 注目/人気/殿堂入りの閾値（カンマ区切り）
# GAME_POST_LEVEL_MAX_HP=100,300,800,2000   # レベル別 max_hp（カンマ区切り）
# GAME_POST_INIT_HP=100           # レス初期HP
# GAME_POST_DECAY_PER_MIN=5       # レスHPの分あたり減衰
# GAME_THREAD_INIT_HP=300         # スレ初期HP
# GAME_THREAD_MAX_HP=1000         # スレ最大HP
# GAME_THREAD_DECAY_PER_MIN=5     # スレHPの分あたり減衰
# GAME_PHASE_MIN_SEC=180          # 相場フェーズの最短継続秒
# GAME_PHASE_MAX_SEC=900          # 相場フェーズの最長継続秒
# GAME_PHASE_BOOM=0.7             # 各フェーズの減衰倍率（boom/calm/storm/crash）
# GAME_PHASE_CALM=1.0
# GAME_PHASE_STORM=1.8
# GAME_PHASE_CRASH=2.5
# GAME_DECAY_MIN_FACTOR=0.3       # 人が居ない時の減衰倍率（過疎でも遊びやすく）
# GAME_DECAY_FULL_AT_HUMANS=20    # この人数で通常速度(×1.0)に到達
# GAME_BOT_MAX_HUMANS=50          # 人間がこの数以下のときだけNPC稼働
# GAME_BOT_TICK_SECONDS=30        # NPCの1アクション間隔（秒）
# GAME_BOT_MAX_BURST=4            # 1リクエストで実行するNPC最大アクション数
# GAME_BOT_MIN_INVEST=30          # NPC1回の最小投資額
# GAME_BOT_MAX_INVEST=150         # NPC1回の最大投資額
# GAME_BOT_REFILL_TO=2000         # 資金切れNPCの補充残高（N1インフレ対策で調整可）
