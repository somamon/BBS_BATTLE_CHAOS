# ---- アプリ ----
APP_ENV=production
APP_URL=https://your-domain.example   # https:// 必須（本番ガードが検証）
APP_TIMEZONE=Asia/Tokyo               # 表示・保存に使うタイムゾーン（PHPとMySQLセッションで共有）

# ---- ポート ----
NGINX_PORT=80
NGINX_TLS_PORT=443
DB_PORT=13306
MAILPIT_UI_PORT=8025                   # 本番では mailpit を起動しない想定

# ---- データベース ----
DB_NAME=bbs
DB_USER=bbs
DB_PASSWORD=            # 本番は強力な秘密に。空/bbs/root 等は起動拒否される
DB_ROOT_PASSWORD=

# ---- メール（本番=SMTPプロバイダ） ----
MAIL_DRIVER=smtp                       # 本番は smtp 必須（log だと実送信されず起動拒否）
MAIL_HOST=smtp.yourprovider.example
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls                    # none | tls(STARTTLS) | ssl
MAIL_FROM=no-reply@your-domain.example
MAIL_FROM_NAME=BBS BATTLE CHAOS
