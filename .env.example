# ============================================================
#  .env サンプル。本番は `cp .env.example .env` して値を埋める。
#  本番デプロイ手順は docs/デプロイ_AWS.md を参照。
# ============================================================

# ---- アプリ ----
APP_ENV=production
APP_URL=https://your-domain.example   # https:// 必須（本番ガードが検証）。↓DOMAINと一致させる
APP_TIMEZONE=Asia/Tokyo               # 表示・保存に使うタイムゾーン（PHPとMySQLセッションで共有）

# ---- 本番ドメイン / TLS（docker-compose.prod.yml / Caddy 用）----
DOMAIN=your-domain.example            # 取得した独自ドメイン（www無し）。CaddyがこのFQDNで証明書を自動取得
ACME_EMAIL=you@example.com            # Let's Encrypt 登録メール（証明書期限の通知先）

# ---- ポート（開発用 docker-compose.yml 専用。本番prodでは未使用）----
NGINX_PORT=80
NGINX_TLS_PORT=443
DB_PORT=13306
MAILPIT_UI_PORT=8025                   # 本番では mailpit を起動しない

# ---- データベース ----
DB_NAME=bbs
DB_USER=bbs
DB_PASSWORD=            # 本番は強力な秘密に。空/bbs/root/password/changeme は起動拒否される
DB_ROOT_PASSWORD=      # これも強力な秘密に

# ---- メール（本番=SMTPプロバイダ。例: Amazon SES）----
MAIL_DRIVER=smtp                       # 本番は smtp 必須（log だと実送信されず起動拒否）
MAIL_HOST=email-smtp.ap-northeast-1.amazonaws.com   # 例: SES東京リージョン
MAIL_PORT=587
MAIL_USERNAME=                         # SES の SMTP ユーザー名（IAM認証情報とは別物）
MAIL_PASSWORD=                         # SES の SMTP パスワード
MAIL_ENCRYPTION=tls                    # none | tls(STARTTLS) | ssl
MAIL_FROM=no-reply@your-domain.example # SESで検証済みの送信元アドレス/ドメイン
MAIL_FROM_NAME=BBS BATTLE CHAOS
